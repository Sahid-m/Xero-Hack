# Xero OAuth app (https://developer.xero.com/app/manage)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Must match redirect URI + scopes in developer.xero.com → your app → Configuration
# Granular scopes required for apps created after Mar 2026 (not accounting.transactions)
XERO_REDIRECT_URI=http://localhost:8000/auth/xero/callback
# Not needed for OAuth — tenant ID is stored per session after connect
XERO_TENANT_ID=
# Xero hosted MCP (Encode hackathon — same OAuth bearer token)
XERO_MCP_URL=https://builders.xero.com/beta/mcp
# From developer.xero.com → your app → Webhooks, after pointing it at /webhooks/xero
# Enables proactive WhatsApp notifications (invoice paid, new bill)
XERO_WEBHOOK_KEY=

# Vercel AI SDK — direct Anthropic provider (requires ai[anthropic,mcp])
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=anthropic:claude-sonnet-4-6
# WhatsApp turns (text + voice-note transcripts via Wassist)
VOICE_AI_MODEL=anthropic:claude-haiku-4-5

# Wassist WhatsApp webhooks — public HTTPS URL (ngrok static domain or deploy URL)
PUBLIC_BASE_URL=https://your-name.ngrok-free.app
NGROK_AUTHTOKEN=
NGROK_STATIC_DOMAIN=your-name.ngrok-free.app

# Wassist BYOA — https://docs.wassist.app/concepts/bring-your-own-agent
WASSIST_API_KEY=
WASSIST_API_BASE=https://backend.wassist.app
# Single Xero org for demo — Demo Company (UK). All WhatsApp → this connection.
WASSIST_DEFAULT_CONNECTION_ID=conv_9501kwqfmzf0frwsza9pakj5spjz

# Session state (Neon / Postgres — file storage used for now)
DATABASE_URL=
